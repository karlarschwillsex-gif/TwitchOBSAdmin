// /home/fynn/TwitchOBSAdmin/server.js
require('dotenv').config();
const express = require('express');
const morgan = require('morgan');
const fs = require('fs');
const path = require('path');
const fetch = require('node-fetch'); // optional forwarding

const app = express();
const PORT = parseInt(process.env.PORT || '3000', 10);
const ROOT = __dirname;

/**
 * CONFIG PATHS
 */
const CONFIG = {
  coins: path.join(ROOT, 'config.json'),
  soundSettings: path.join(ROOT, 'sound_settings.json'),
  soundAlias: path.join(ROOT, 'sound_alias.json'),
  camFilterSettings: path.join(ROOT, 'effects-config.json'),
  bannerFolder: path.join(ROOT, 'public', 'banner'),
  creditsLayout: path.join(ROOT, 'credits-layout.json'),
  pinFile: path.join(ROOT, 'admin_config.json')
};

// Ensure directories exist
try {
  if (!fs.existsSync(path.join(ROOT, 'public'))) fs.mkdirSync(path.join(ROOT, 'public'), { recursive: true });
  if (!fs.existsSync(CONFIG.bannerFolder)) fs.mkdirSync(CONFIG.bannerFolder, { recursive: true });
} catch (err) {
  console.error('[server] Fehler beim Anlegen von Verzeichnissen', err);
}

/**
 * Middleware
 */
app.use(morgan('dev'));
app.use(express.json({ limit: '2mb' }));
app.use(express.urlencoded({ extended: true }));
app.use(express.static(path.join(ROOT, 'public')));

/**
 * Utility helpers
 */
function ensureFile(filePath, defaultContent) {
  if (!fs.existsSync(filePath)) {
    try {
      fs.writeFileSync(filePath, JSON.stringify(defaultContent, null, 2));
    } catch (err) {
      console.error(`[server] Fehler beim Anlegen ${filePath}`, err);
    }
  }
}

function safeReadJson(filePath, defaultObj = {}) {
  try {
    ensureFile(filePath, defaultObj);
    return JSON.parse(fs.readFileSync(filePath, 'utf8'));
  } catch (err) {
    console.error(`[server] safeReadJson Fehler ${filePath}`, err);
    return defaultObj;
  }
}

function safeWriteJson(filePath, obj) {
  try {
    fs.writeFileSync(filePath, JSON.stringify(obj, null, 2));
    return true;
  } catch (err) {
    console.error(`[server] safeWriteJson Fehler ${filePath}`, err);
    return false;
  }
}

/**
 * PIN helpers
 */
function loadPin() {
  try {
    ensureFile(CONFIG.pinFile, { pin: process.env.ADMIN_PIN || '1234' });
    const raw = fs.readFileSync(CONFIG.pinFile, 'utf8');
    const obj = JSON.parse(raw);
    return obj.pin;
  } catch (err) {
    console.error('[server] loadPin Fehler', err);
    return process.env.ADMIN_PIN || '1234';
  }
}

function savePin(newPin) {
  try {
    fs.writeFileSync(CONFIG.pinFile, JSON.stringify({ pin: newPin }, null, 2));
    return true;
  } catch (err) {
    console.error('[server] savePin Fehler', err);
    return false;
  }
}

/**
 * Basic endpoints
 */
app.get('/', (req, res) => {
  const adminHtml = path.join(ROOT, 'public', 'admin.html');
  if (fs.existsSync(adminHtml)) return res.sendFile(adminHtml);
  res.type('text').send('Admin-Backend läuft');
});

app.get('/_status', (req, res) => {
  res.json({
    status: 'ok',
    time: new Date().toISOString(),
    env: {
      port: PORT,
      eventsub_callback: process.env.TWITCH_EVENTSUB_CALLBACK || null
    }
  });
});

/**
 * EventSub callback endpoint
 * - Loggt die Payload
 * - Optional: forwarded an local EventSub listener (z.B. eventsub.js)
 */
app.post('/eventsub', async (req, res) => {
  try {
    console.log('[eventsub] Payload empfangen:', {
      type: req.body?.subscription?.type || 'unknown',
      id: req.body?.subscription?.id || null
    });

    // Optional forwarding to local eventsub service
    const forwardTo = process.env.EVENTSUB_FORWARD || process.env.TWITCH_EVENTSUB_FORWARD;
    if (forwardTo) {
      try {
        await fetch(forwardTo, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(req.body),
          timeout: 5000
        });
        console.log('[eventsub] Weitergeleitet an', forwardTo);
      } catch (fwdErr) {
        console.warn('[eventsub] Weiterleitung fehlgeschlagen', fwdErr.message || fwdErr);
      }
    }

    res.status(200).send('ok');
  } catch (err) {
    console.error('[eventsub] Fehler beim Verarbeiten', err);
    res.status(500).send('error');
  }
});

/**
 * Admin auth: login + middleware
 */
app.post('/api/admin/login', (req, res) => {
  const { pin } = req.body || {};
  if (pin === loadPin()) return res.json({ ok: true });
  return res.status(401).json({ error: 'Falsche PIN' });
});

app.use('/api/admin', (req, res, next) => {
  const pin = req.headers['x-admin-pin'];
  if (pin !== loadPin()) return res.status(401).json({ error: 'Unauthorized' });
  next();
});

/**
 * Config endpoints (coins, sound, alias, camfilter)
 */
app.get('/api/admin/config', (req, res) => res.json(safeReadJson(CONFIG.coins, {})));
app.post('/api/admin/config', (req, res) => { safeWriteJson(CONFIG.coins, req.body || {}); res.json({ ok: true }); });

app.get('/api/admin/sound-settings', (req, res) => res.json(safeReadJson(CONFIG.soundSettings, {})));
app.post('/api/admin/sound-settings', (req, res) => { safeWriteJson(CONFIG.soundSettings, req.body || {}); res.json({ ok: true }); });

app.get('/api/admin/sound-alias', (req, res) => res.json(safeReadJson(CONFIG.soundAlias, {})));
app.post('/api/admin/sound-alias', (req, res) => { safeWriteJson(CONFIG.soundAlias, req.body || {}); res.json({ ok: true }); });

app.get('/api/admin/camfilter-settings', (req, res) => res.json(safeReadJson(CONFIG.camFilterSettings, {})));
app.post('/api/admin/camfilter-settings', (req, res) => { safeWriteJson(CONFIG.camFilterSettings, req.body || {}); res.json({ ok: true }); });

/**
 * Banner endpoints
 */
app.get('/api/admin/banner', (req, res) => {
  const bannerPath = path.join(CONFIG.bannerFolder, 'banner.png');
  res.json({ exists: fs.existsSync(bannerPath) });
});

app.post('/api/admin/banner', (req, res) => {
  try {
    const { imageBase64 } = req.body || {};
    if (!imageBase64) return res.status(400).json({ error: 'imageBase64 fehlt' });
    const data = imageBase64.replace(/^data:image\/\w+;base64,/, '');
    fs.writeFileSync(path.join(CONFIG.bannerFolder, 'banner.png'), Buffer.from(data, 'base64'));
    return res.json({ ok: true });
  } catch (err) {
    console.error('[server] banner upload error', err);
    return res.status(500).json({ error: 'Speicherfehler' });
  }
});

app.delete('/api/admin/banner', (req, res) => {
  try {
    const bannerPath = path.join(CONFIG.bannerFolder, 'banner.png');
    if (fs.existsSync(bannerPath)) fs.unlinkSync(bannerPath);
    return res.json({ ok: true });
  } catch (err) {
    console.error('[server] banner delete error', err);
    return res.status(500).json({ error: 'Löschfehler' });
  }
});

/**
 * Credits API (file-based)
 * - GET /api/admin/credits/:id?   -> { credits: number }
 * - POST /api/admin/credits/:id?  -> { delta: n } or { credits: n }
 * - DELETE /api/admin/credits/:id? -> reset to 0
 */
const CREDITS_DATA_DIR = process.env.CREDITS_DATA_DIR
  ? path.resolve(process.env.CREDITS_DATA_DIR)
  : path.join(ROOT, 'twitch-credits', 'data', 'credits');

try { if (!fs.existsSync(CREDITS_DATA_DIR)) fs.mkdirSync(CREDITS_DATA_DIR, { recursive: true }); } catch (e) { console.error('[server] CREDITS_DATA_DIR error', e); }

function creditsFilePath(id = 'global') {
  const safe = String(id || 'global').replace(/[^a-zA-Z0-9-_]/g, '_');
  return path.join(CREDITS_DATA_DIR, `${safe}.json`);
}

function readCredits(id = 'global') {
  const fp = creditsFilePath(id);
  try {
    if (!fs.existsSync(fp)) fs.writeFileSync(fp, JSON.stringify({ credits: 0 }, null, 2));
    return JSON.parse(fs.readFileSync(fp, 'utf8'));
  } catch (err) {
    console.error('[server] readCredits Fehler', err);
    return { credits: 0 };
  }
}

function writeCredits(id = 'global', obj = { credits: 0 }) {
  const fp = creditsFilePath(id);
  try {
    fs.writeFileSync(fp, JSON.stringify(obj, null, 2));
    return true;
  } catch (err) {
    console.error('[server] writeCredits Fehler', err);
    return false;
  }
}

// GET all or specific
app.get('/api/admin/credits', (req, res) => {
  res.json(readCredits('global'));
});
app.get('/api/admin/credits/:id', (req, res) => {
  res.json(readCredits(req.params.id || 'global'));
});

// POST update (global)
app.post('/api/admin/credits', (req, res) => {
  const id = 'global';
  const body = req.body || {};
  const current = readCredits(id);
  if (typeof body.credits === 'number') {
    const ok = writeCredits(id, { credits: body.credits });
    return ok ? res.json({ ok: true, credits: body.credits }) : res.status(500).json({ error: 'write failed' });
  }
  if (typeof body.delta === 'number') {
    const newVal = (current.credits || 0) + body.delta;
    const ok = writeCredits(id, { credits: newVal });
    return ok ? res.json({ ok: true, credits: newVal }) : res.status(500).json({ error: 'write failed' });
  }
  return res.status(400).json({ error: 'invalid payload, use {credits:number} or {delta:number}' });
});
app.post('/api/admin/credits/:id', (req, res) => {
  const id = req.params.id || 'global';
  const body = req.body || {};
  const current = readCredits(id);
  if (typeof body.credits === 'number') {
    const ok = writeCredits(id, { credits: body.credits });
    return ok ? res.json({ ok: true, credits: body.credits }) : res.status(500).json({ error: 'write failed' });
  }
  if (typeof body.delta === 'number') {
    const newVal = (current.credits || 0) + body.delta;
    const ok = writeCredits(id, { credits: newVal });
    return ok ? res.json({ ok: true, credits: newVal }) : res.status(500).json({ error: 'write failed' });
  }
  return res.status(400).json({ error: 'invalid payload, use {credits:number} or {delta:number}' });
});

// DELETE reset
app.delete('/api/admin/credits', (req, res) => {
  const ok = writeCredits('global', { credits: 0 });
  return ok ? res.json({ ok: true, credits: 0 }) : res.status(500).json({ error: 'reset failed' });
});
app.delete('/api/admin/credits/:id', (req, res) => {
  const id = req.params.id || 'global';
  const ok = writeCredits(id, { credits: 0 });
  return ok ? res.json({ ok: true, credits: 0 }) : res.status(500).json({ error: 'reset failed' });
});


/**
 * Credits webhook helper (optional)
 * If you want server to notify local credits service or overlay, set CREDITS_NOTIFY_URL in .env
 */
app.post('/api/admin/credits/notify/:id?', (req, res) => {
  const id = req.params.id || 'global';
  const notifyUrl = process.env.CREDITS_NOTIFY_URL;
  if (!notifyUrl) return res.status(400).json({ error: 'CREDITS_NOTIFY_URL not configured' });
  const data = readCredits(id);
  fetch(notifyUrl, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ id, data })
  }).then(() => res.json({ ok: true })).catch(err => {
    console.error('[server] credits notify failed', err);
    res.status(500).json({ error: 'notify failed' });
  });
});

/**
 * Change PIN
 */
app.post('/api/admin/change-pin', (req, res) => {
  const { oldPin, newPin } = req.body || {};
  if (oldPin !== loadPin()) return res.status(401).json({ error: 'Falsche alte PIN' });
  if (!savePin(newPin)) return res.status(500).json({ error: 'Konnte PIN nicht speichern' });
  res.json({ ok: true });
});

/**
 * Global error handler
 */
app.use((err, req, res, next) => {
  console.error('[server] Fehler:', err && err.stack ? err.stack : err);
  res.status(500).json({ error: 'Internal Server Error' });
});

/**
 * Graceful shutdown
 */
const server = app.listen(PORT, () => {
  console.log(`Admin-Backend läuft auf http://localhost:${PORT}`);
});

function shutdown() {
  console.log('[server] Beende Server...');
  server.close(() => {
    console.log('[server] HTTP Server beendet');
    process.exit(0);
  });
  setTimeout(() => {
    console.warn('[server] Forciertes Beenden');
    process.exit(1);
  }, 5000).unref();
}

process.on('SIGINT', shutdown);
process.on('SIGTERM', shutdown);

